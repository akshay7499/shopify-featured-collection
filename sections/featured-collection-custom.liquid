<section class="page-width">

  <h1 class="fc-collection-title">{{ collection.title }}</h1>

  <div id="fc-filter-bar" style="margin-bottom: 20px; display: flex; flex-wrap: wrap; gap: 10px; align-items: center;">
    <select id="fc-filter-tag">
      <option value="">All categories</option>
    </select>
    <select id="fc-sort-select">
      <option value="">Default</option>
      <option value="price-asc">Price: Low to High</option>
      <option value="price-desc">Price: High to Low</option>
      <option value="title-asc">Name: A-Z</option>
      <option value="title-desc">Name: Z-A</option>
    </select>
    <button id="fc-clear-filters">Clear filters</button>
  </div>

  <div id="fc-product-grid">
    <div class="fc-grid" id="fc-grid-container"></div>
  </div>

  <div id="fc-loader">
    <div class="fc-skeleton-grid" id="fc-skeleton-grid"></div>
    <p id="fc-end-message" style="display:none;">No more products</p>
  </div>

</section>

<script>
  const collectionHandle = {{ collection.handle | json }};

  let currentPage = 1;
  let loading = false;
  let allFeatured = [];
  let allNormal = [];
  let displayedIds = new Set();
  let featuredComplete = false;
  let activeTag = '';
  let activeSort = '';
  let normalDisplayedCount = 0;

  const grid = document.getElementById('fc-grid-container');
  const loader = document.getElementById('fc-loader');
  const skeletonGrid = document.getElementById('fc-skeleton-grid');
  const endMessage = document.getElementById('fc-end-message');
  const filterTag = document.getElementById('fc-filter-tag');
  const sortSelect = document.getElementById('fc-sort-select');
  const clearBtn = document.getElementById('fc-clear-filters');

  const allTagsSet = new Set();

  /* ── Skeleton ── */
  function showSkeleton(count = 4) {
    skeletonGrid.innerHTML = '';
    for (let i = 0; i < count; i++) {
      skeletonGrid.innerHTML += `
        <div class="fc-skeleton-card">
          <div class="fc-skeleton fc-skeleton-img"></div>
          <div class="fc-skeleton fc-skeleton-title"></div>
          <div class="fc-skeleton fc-skeleton-title fc-short"></div>
          <div class="fc-skeleton fc-skeleton-price"></div>
        </div>`;
    }
    loader.style.display = 'block';
    endMessage.style.display = 'none';
  }

  function hideSkeleton() {
    skeletonGrid.innerHTML = '';
    loader.style.display = 'none';
  }

  function showEndMessage() {
    skeletonGrid.innerHTML = '';
    endMessage.style.display = 'block';
    loader.style.display = 'block';
  }

  /* ── Tag filter dropdown ── */
  function populateTagFilter() {
    const current = filterTag.value;
    filterTag.innerHTML = '<option value="">All categories</option>';
    [...allTagsSet]
      .filter(t => t !== 'featured')
      .sort()
      .forEach(tag => {
        const opt = document.createElement('option');
        opt.value = tag;
        opt.textContent = tag.charAt(0).toUpperCase() + tag.slice(1);
        filterTag.appendChild(opt);
      });
    filterTag.value = current;
  }

  /* ── Fetch from Shopify API ── */
  async function fetchProducts(page) {
    if (loading) return;
    loading = true;
    showSkeleton(page === 1 ? 8 : 4);

    try {
      const limit = 250;
      const res = await fetch(`/collections/${collectionHandle}/products.json?limit=${limit}&page=${page}`);
      const data = await res.json();

      if (!data.products || !data.products.length) {
        featuredComplete = true;
        hideSkeleton();
        loading = false;
        return;
      }

      data.products.forEach(product => {
        if (displayedIds.has(product.id)) return;
        displayedIds.add(product.id);

        const rawTags = product.tags || '';
        const tags = (typeof rawTags === 'string' ? rawTags : rawTags.join(','))
          .split(',').map(t => t.toLowerCase().trim()).filter(t => t !== '');

        tags.filter(t => t !== 'featured').forEach(t => allTagsSet.add(t));

        if (tags.includes('featured') && allFeatured.length < 15) {
          allFeatured.push(product);
        } else {
          allNormal.push(product);
        }
      });

      populateTagFilter();

      // Keep scanning pages until all 15 featured are found
      if (!featuredComplete && allFeatured.length < 15 && data.products.length === limit) {
        currentPage++;
        loading = false;
        await fetchProducts(currentPage);
        return;
      }

      featuredComplete = true;
      renderProducts();

    } catch (err) {
      console.error('[FC] fetch error:', err);
    }

    hideSkeleton();
    loading = false;
  }

  /* ── Filter + sort helpers ── */
  function filterPool(pool) {
    if (!activeTag) return [...pool];
    return pool.filter(p => {
      const rawTags = p.tags || '';
      const tags = (typeof rawTags === 'string' ? rawTags : rawTags.join(','))
        .split(',').map(t => t.toLowerCase().trim()).filter(t => t !== '');
      return tags.includes(activeTag);
    });
  }

  function sortPool(pool) {
    const sorted = [...pool];
    switch (activeSort) {
      case 'price-asc':
        sorted.sort((a, b) => parseFloat(a.variants[0].price) - parseFloat(b.variants[0].price));
        break;
      case 'price-desc':
        sorted.sort((a, b) => parseFloat(b.variants[0].price) - parseFloat(a.variants[0].price));
        break;
      case 'title-asc':
        sorted.sort((a, b) => a.title.localeCompare(b.title));
        break;
      case 'title-desc':
        sorted.sort((a, b) => b.title.localeCompare(a.title));
        break;
    }
    return sorted;
  }

  /* ── Full re-render on filter/sort change ── */
  function renderProducts() {
    grid.innerHTML = '';
    normalDisplayedCount = 0;

    const filteredFeatured = sortPool(filterPool(allFeatured));
    const filteredNormal   = sortPool(filterPool(allNormal));

    // Show all matching featured first (up to 15)
    filteredFeatured.slice(0, 15).forEach(p => grid.appendChild(createCard(p, true)));

    // Show first 5 normal products (total = 20 on first load)
    const initialNormal = filteredFeatured.length >= 15 ? 5 : 20 - filteredFeatured.length;
    filteredNormal.slice(0, initialNormal).forEach(p => grid.appendChild(createCard(p, false)));
    normalDisplayedCount = Math.min(filteredNormal.length, initialNormal);

    if (filteredFeatured.length === 0 && filteredNormal.length === 0) {
      grid.innerHTML = '<p style="grid-column:1/-1;text-align:center;padding:40px;color:#555;">No products match this filter.</p>';
    }

    hideSkeleton();
  }

  /* ── Append next 20 normal products on scroll ── */
  function appendMoreNormal() {
    const filteredNormal = sortPool(filterPool(allNormal));
    const nextBatch = filteredNormal.slice(normalDisplayedCount, normalDisplayedCount + 20);

    if (!nextBatch.length) {
      showEndMessage();
      return;
    }

    nextBatch.forEach(p => grid.appendChild(createCard(p, false)));
    normalDisplayedCount += nextBatch.length;

    if (normalDisplayedCount >= filteredNormal.length) {
      showEndMessage();
    } else {
      hideSkeleton();
    }
  }

  /* ── Create product card ── */
  function createCard(product, featured) {
    const div = document.createElement('div');
    div.className = 'fc-card fc-reveal';
    div.setAttribute('data-id', product.id);

    const image = product.images && product.images.length ? product.images[0].src : '';
    const price = product.variants && product.variants[0]
      ? '₹' + parseFloat(product.variants[0].price).toLocaleString('en-IN')
      : '';

    div.innerHTML = `
      <a href="/products/${product.handle}">
        <div class="fc-card-img-wrap">
          <img src="${image}" alt="${product.title}" loading="lazy" />
        </div>
        <div class="fc-card-info">
          ${featured ? '<span class="fc-featured-tag">Featured</span>' : ''}
          <h3>${product.title}</h3>
          <p class="fc-price">${price}</p>
        </div>
      </a>
    `;
    return div;
  }

  /* ── Events ── */
  filterTag.addEventListener('change', () => {
    activeTag = filterTag.value;
    renderProducts();
  });

  sortSelect.addEventListener('change', () => {
    activeSort = sortSelect.value;
    renderProducts();
  });

  clearBtn.addEventListener('click', () => {
    activeTag = '';
    activeSort = '';
    filterTag.value = '';
    sortSelect.value = '';
    renderProducts();
  });

  /* ── Infinite scroll ── */
  window.addEventListener('scroll', async () => {
    if (loading) return;
    if (!featuredComplete) return;
    if (window.innerHeight + window.scrollY < document.body.offsetHeight - 300) return;

    const filteredNormal = sortPool(filterPool(allNormal));

    // If we have buffered normal products not yet shown, show next batch
    if (normalDisplayedCount < filteredNormal.length) {
      showSkeleton(4);
      setTimeout(() => appendMoreNormal(), 400);
      return;
    }

    // Otherwise fetch next API page
    currentPage++;
    await fetchProducts(currentPage);
    appendMoreNormal();
  });

  /* ── Boot ── */
  fetchProducts(currentPage);
</script>

<style>
  .fc-collection-title {
    margin-bottom: 20px;
  }

  #fc-filter-bar select,
  #fc-filter-bar button {
    padding: 8px 12px;
    border: 1px solid #ddd;
    background: #fff;
    font-size: 14px;
    cursor: pointer;
  }

  #fc-filter-bar select:focus,
  #fc-filter-bar button:hover {
    border-color: #00c9d4;
    outline: none;
  }

  *:focus-visible {
    outline: unset !important;
    outline-offset: unset !important;
    box-shadow: unset !important;
  }

  #fc-clear-filters {
    background: #f5f5f5;
  }

  .fc-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .fc-skeleton-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 20px;
  }

  .fc-skeleton-card {
    border: 1px solid #eee;
    padding: 10px;
    border-radius: 4px;
  }

  .fc-skeleton {
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: shimmer 1.4s infinite;
    border-radius: 4px;
  }

  .fc-skeleton-img   { width: 100%; height: 250px; margin-bottom: 10px; }
  .fc-skeleton-title { height: 16px; width: 80%; margin: 0 auto 8px; }
  .fc-skeleton-title.fc-short { width: 55%; }
  .fc-skeleton-price { height: 14px; width: 40%; margin: 0 auto; }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  #fc-loader { padding: 20px 0; }

  #fc-end-message {
    text-align: center;
    padding: 20px;
    color: #888;
    font-size: 14px;
  }

  /* ── Card ── */
  .fc-card {
    border: 1px solid #eee;
    padding: 10px;
    text-align: center;
    transition: 0.3s;
    opacity: 0;
  }

  .fc-card:hover { transform: translateY(-5px); }

  .fc-card a {
    text-decoration: none;
    color: #000;
  }

  .fc-card-img-wrap {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
  }

  .fc-card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .fc-card-info {
    padding: 10px 0 4px;
  }

  .fc-card-info h3 {
    margin: 6px 0 4px;
    font-size: 14px;
    font-weight: 600;
  }

  .fc-card-info .fc-price {
    margin: 0;
    font-size: 14px;
    color: #333;
  }

  .fc-featured-tag {
    display: inline-block;
    background: #fff7e0;
    color: #b45309;
    font-size: 16px;
    font-weight: 700;
    padding: 2px 8px;
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    width: 50%;
    position: absolute;
    top: 0;
    left: 0;
 }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .fc-card.fc-reveal { animation: fadeInUp 0.5s ease forwards; }

  @media screen and (max-width: 749px) {
    .fc-grid,
    .fc-skeleton-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
    #fc-filter-bar {
      flex-direction: column;
      align-items: unset !important;
    }
  }
</style>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select collection"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
